.SS Adding a new target (build.cpp)
.nf
project->add_target({
    .name               = "MyTarget",
    .optimization_level = 1,
    .sanitizers         = ASan | UBSan,
    .defines            = { "DEBUG", "MY_DEFINE" },
    .compiler_flags     = { "g", "Wall", "Werror", "pedantic" }
});
.fi

.SS Adding libraries and dependencies (build.cpp)
.nf
// Dynamic linking with a system copy by default
project->add_dependency({ .name = "lib_name" });

// Dynamic linking with a system copy explicitly
project->add_dependency({
    .name     = "lib_name",
    .linking  = Linking::Dynamic,
    .location = Location::System
});

// Dynamic linking with a local copy
project->add_dependency({
    .name     = "lib_name",
    .linking  = Linking::Dynamic,
    .location = Location::Local
});

// Static linking (location is ignored, assumed Local)
project->add_dependency({
    .name    = "lib_name",
    .linking = Linking::Static
});

// Single Header dependency
project->add_dependency({
    .name    = "lib_name",
    .linking = Linking::SingleHeader
});
.fi

.SS Adding pre/post build scripts (build.cpp)
.nf
bool foo() { /* do something */      return true; }
bool bar() { /* do something else */ return true; }

project->add_pre_build_script({ .func = foo, .name = "Foo" });
project->add_post_build_script({ .func = bar, .name = "Bar" });
.fi

.SH FILES
.TP
.B build.cpp
The configuration file where the project is defined.

.TP
.B ./build
The output directory containing binaries, object files, and dependency information.

.TP
.B lib/
Directory for local libraries and single-header dependencies.

.TP
.B src/
Directory for source code.

.SH SEE ALSO
g++, clang++, make

.SH BUGS
Only Clang and GCC are supported currently.

The test command is currently unimplemented.

macOS local dynamic linking relies on the install name matching the file name.

